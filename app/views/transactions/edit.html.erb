<header>
  <h1><%= "#{@transaction.creditor} ➡️ #{@transaction.debitor}" %></h1>
  <nav>
    <%= link_to @transaction do %>
      <b><%= t('common.show') %></b>
    <% end %>
  </nav>
</header>
<article>
  <%= render partial: 'form' %>
</article>

<% unless @transaction.transfer? %>
  <%= turbo_frame_tag "transaction_links" do %>
    <%= render "transaction_links/balance_table", transaction: @transaction %>
    <%= render "transaction_links/suggestions", transaction: @transaction %>
  <% end %>
<% end %>

<div class="actions">
  <%= button_to t('common.destroy'), @transaction, method: :delete, class: "button-danger", data: { turbo_confirm: t('common.confirm_destroy') } %>
</div>
