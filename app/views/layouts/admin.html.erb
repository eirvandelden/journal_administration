<!DOCTYPE html>
<html <%= tag.attributes(theme_attributes) %> data-controller="theme">
  <head>
    <title>Admin - <%= Rails.application.class.module_parent_name %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="turbo-cache-control" content="no-cache">
    <meta name="view-transition" content="same-origin">
    <meta name="color-scheme" content="light dark">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= render "appkit/shared/pwa_meta" %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header>
      <nav>
        <ul>
          <li><%= link_to t("admin.nav.dashboard"), admin_root_path, "aria-current": ("page" if current_page?(admin_root_path)) %></li>
          <li><%= link_to t("admin.nav.users"), admin_users_path, "aria-current": ("page" if current_page?(admin_users_path)) %></li>
          <li><%= link_to t("admin.nav.back_to_site"), root_path %></li>
        </ul>
      </nav>
    </header>

    <main>
      <%= render "appkit/shared/flashes" %>

      <%= yield %>
    </main>

    <dialog id="confirm-dialog">
      <p id="confirm-dialog-message"></p>
      <nav>
        <button type="button" id="confirm-dialog-cancel" autofocus><%= t("common.cancel") %></button>
        <button type="button" id="confirm-dialog-accept" class="button-danger" data-default-label="<%= t("common.delete") %>"></button>
      </nav>
    </dialog>
  </body>
</html>
