<header>
  <h1><%= @category.name %></h1>
  <nav>
    <%= link_to @category do %>
      <b><%= t('common.show') %></b>
    <% end %>
  </nav>
</header>
<article>
  <%= render 'form' %>
</article>

<article>
  <%= render "shared/recent_transactions", transactions: @category.recent_transactions %>
</article>

<div class="actions">
  <%= button_to t('common.destroy'), @category, method: :delete, class: "button-danger", data: { turbo_confirm: t('common.confirm_destroy'), confirm_verb: t('common.delete') } %>
</div>
