<% @category_groups.each do |parent, categories| %>
  <section>
    <h2><%= parent&.name || t('.root_categories') %></h2>

    <table class="categories">
      <thead>
        <tr>
          <th></th>
          <th><%= t('.id') %></th>
          <th><%= t('.name') %></th>
        </tr>
      </thead>
      <tbody>
        <% categories.each do |category| %>
          <tr>
            <td><%= link_to t('.show'), category %></td>
            <td><%= category.id %></td>
            <td><%= category.name %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
<% end %>

<section>
  <%= link_to t('.new_category'), new_category_path %>
</section>
