<header>
  <h1><%= @account.name %></h1>
  <nav>
    <%= link_to @account do %>
      <b><%= t('common.show') %></b>
    <% end %>
  </nav>
</header>
<article>
  <%= render 'form', account: @account %>
</article>

<article>
  <%= render "shared/recent_transactions", transactions: @account.recent_transactions %>
</article>
