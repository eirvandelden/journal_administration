<header>
  <h1><%= @account.name %></h1>
  <nav>
    <%= link_to edit_account_path(@account) do %>
      <b><%= t('.edit') %></b>
    <% end %>
  </nav>
</header>

<article>
<p>
  <b><%= t('.id') %></b>
  <%= @account.id %>
</p>
<p>
  <b><%= t('.account_number') %></b>
  <%= @account.account_number %>
</p>
<p>
  <b><%= t('.name') %></b>
  <%= @account.name %>
</p>
<p>
  <b><%= t('.owner') %></b>
  <%= @account.owner %>
</p>
<p>
  <b><%= t('.category') %></b>
  <%= @account.category&.name %>
</p>

<%= button_to t('.update_transactions'), account_transactions_bulk_path(@account), method: :patch %>
</article>

<% if @account.external? %>
  <article>
    <h2><%= t(".aliases") %></h2>
    <ul>
      <%= render @account.account_aliases %>
    </ul>
    <%= render "account_aliases/form", account: @account, account_alias: @account.account_aliases.build %>
  </article>
<% end %>

<article>
  <%= render "shared/recent_transactions", transactions: @account.recent_transactions %>
</article>
