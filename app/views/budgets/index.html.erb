<h1><%= t("budgets.index.title") %></h1>
<p><%= link_to t("budgets.index.new_budget"), new_budget_path %></p>

<table>
  <thead>
    <tr>
      <th><%= t("budgets.index.date_range") %></th>
      <th><%= t("budgets.index.status") %></th>
      <th><%= t("budgets.index.categories") %></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @budgets.each do |budget| %>
      <tr>
        <td>
          <%= l(budget.starts_at.to_date, format: :long) %>
          <% if budget.ends_at %>
            &ndash; <%= l(budget.ends_at.to_date, format: :long) %>
          <% end %>
        </td>
        <td>
          <% if budget.active? %>
            <span><%= t("budgets.index.active") %></span>
          <% elsif budget.future? %>
            <span><%= t("budgets.index.future") %></span>
          <% else %>
            <span><%= t("budgets.index.past") %></span>
          <% end %>
        </td>
        <td><%= budget.budget_categories.size %></td>
        <td>
          <%= link_to t("budgets.index.edit"), edit_budget_path(budget) %>
          <%= button_to t("budgets.index.delete"), budget_path(budget), method: :delete,
              data: { turbo_confirm: t("budgets.index.confirm_destroy") } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
