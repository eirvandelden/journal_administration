<article>
  <%= form_with url: dashboard_index_path, method: :get, data: { controller: "date-filter" } do |f| %>
    <fieldset>
      <label><%= t("dashboard.filters.quick_filter") %></label>
      <select data-date-filter-target="quickFilter" data-action="change->date-filter#applyQuickFilter">
        <option value="">-- <%= t("dashboard.filters.select") %> --</option>
        <option value="current_month"><%= t("dashboard.filters.current_month") %></option>
        <option value="last_month"><%= t("dashboard.filters.last_month") %></option>
        <option value="three_months"><%= t("dashboard.filters.three_months") %></option>
        <option value="current_year"><%= t("dashboard.filters.current_year") %></option>
        <option value="last_year"><%= t("dashboard.filters.last_year") %></option>
      </select>
    </fieldset>

    <fieldset>
      <%= f.label :start_date, t("dashboard.filters.start_date") %>
      <%= f.date_field :start_date, value: @dashboard.date_range.start_date.to_date, data: { "date-filter-target": "startDate" } %>
    </fieldset>

    <fieldset>
      <%= f.label :end_date, t("dashboard.filters.end_date") %>
      <%= f.date_field :end_date, value: @dashboard.date_range.end_date.to_date, data: { "date-filter-target": "endDate" } %>
    </fieldset>

    <button type="submit"><%= t("dashboard.filters.apply") %></button>
  <% end %>
</article>

<article>
  <section class="chart-section">
    <h2><%= t("dashboard.charts.spending_by_category") %></h2>
    <%= svg_donut_chart(labels: @dashboard.chart_labels, data: @dashboard.credit_transactions.values.map(&:to_f)) %>
  </section>
</article>

<article>
  <%= render partial: "balance", locals: { dashboard: @dashboard } %>
</article>

<article>
  <section class="chart-section">
    <% if @dashboard.active_budget %>
      <h2><%= t("dashboard.charts.budget_vs_actual") %></h2>
      <%= svg_budget_chart(budget: @dashboard.active_budget,
                           debit_transactions: @dashboard.debit_transactions,
                           credit_transactions: @dashboard.credit_transactions) %>
    <% else %>
      <h2><%= t("dashboard.charts.spending_vs_average") %></h2>
      <%= svg_bar_chart(labels: @dashboard.chart_labels,
                        data: @dashboard.credit_transactions.values.map(&:to_f),
                        reference: @dashboard.historical_averages,
                        y_label: t("dashboard.charts.spending_vs_average")) %>
    <% end %>
  </section>
</article>
