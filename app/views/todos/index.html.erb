<section class="todo-list">
  <% if @empty %>
    <p><%= t('.empty') %></p>
  <% else %>
    <%= render "shared/pagination", page: @page %>
    <table class="todo">
      <thead>
        <tr>
          <th><%= t('.date') %></th>
          <th><%= t('.kind') %></th>
          <th><%= t('.description') %></th>
          <th><%= t('.actions') %></th>
        </tr>
      </thead>
      <tbody>
        <% @items.each do |item| %>
          <tr>
            <td><%= l item.date, format: :short %></td>
            <% if item.kind == :transaction %>
              <td><%= t('.transaction') %></td>
              <td>
                <%= item.record.note&.truncate(40) %>
                <%= number_to_currency item.record.uncategorized_amount %>
              </td>
              <td><%= link_to t('.edit'), edit_transaction_path(item.record) %></td>
            <% else %>
              <td><%= t('.account') %></td>
              <td><%= item.record.to_s %></td>
              <td>
                <%= link_to t('.edit'), edit_account_path(item.record) %>
                <%= button_to t('.update_transactions'), account_transactions_bulk_path(item.record), method: :patch %>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
    <%= render "shared/pagination", page: @page %>
  <% end %>
</section>
