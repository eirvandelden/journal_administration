<%# locals: (user:) %>
<div class="flex flex-column align-center gap txt-medium--responsive">
  <% url = session_transfer_url(user.transfer_id) %>
  <% transfer_label = Current.user != user ? t("users.transfer.other_title") : t("users.transfer.self_title") %>

  <label class="flex flex-column gap full-width">
    <div class="flex align-center gap">
      <% if Current.user != user %>
        <%= translation_button(:transfer_session) %>
      <% else %>
        <%= translation_button(:transfer_session_self) %>
      <% end %>
      <strong id="session_transfer_label" class="txt-align-start"><%= transfer_label %></strong>
    </div>
    <span class="flex align-center gap margin-inline">
      <input type="text"
             class="input fill-white"
             id="session_transfer_url"
             value="<%= url %>"
             aria-labelledby="session_transfer_label"
             autocomplete="off"
             readonly>
    </span>
  </label>

  <div class="flex align-center gap">
    <%= tag.button type: "button", class: "btn",
                   data: { controller: "clipboard", action: "clipboard#copy", clipboard_text_value: url } do %>
      <span aria-hidden="true">📋</span>
      <span class="for-screen-reader"><%= t("users.transfer.copy") %></span>
    <% end %>

    <%= tag.button type: "button",
                   class: "btn",
                   data: {
                     controller: "web-share",
                     action: "web-share#share",
                     web_share_url_value: url,
                     web_share_title_value: t("users.transfer.share_title"),
                     web_share_text_value: t("users.transfer.share_text"),
                   } do %>
      <span aria-hidden="true">📤</span>
      <span class="for-screen-reader"><%= t("users.transfer.share") %></span>
    <% end %>
  </div>
</div>
