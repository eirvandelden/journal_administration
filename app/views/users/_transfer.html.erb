<%# locals: (user:) %>
<% url = session_transfer_url(user.transfer_id) %>
<% transfer_label = Current.user != user ? t("users.transfer.other_title") : t("users.transfer.self_title") %>

<label for="session_transfer_url">
  <strong><%= transfer_label %></strong>
</label>
<input type="text"
       id="session_transfer_url"
       value="<%= url %>"
       autocomplete="off"
       readonly>

<ul>
  <li>
    <%= tag.button type: "button",
                   data: { controller: "clipboard", action: "clipboard#copy", clipboard_text_value: url } do %>
      <span aria-hidden="true">📋</span>
      <%= t("users.transfer.copy") %>
    <% end %>
  </li>

  <li>
    <%= tag.button type: "button",
                   data: {
                     controller: "web-share",
                     action: "web-share#share",
                     web_share_url_value: url,
                     web_share_title_value: t("users.transfer.share_title"),
                     web_share_text_value: t("users.transfer.share_text"),
                   } do %>
      <span aria-hidden="true">📤</span>
      <%= t("users.transfer.share") %>
    <% end %>
  </li>
</ul>
